<mujoco model="flex_reference_composite_cable_improve">
  <!--
    composite_improve: 优化版 composite 线缆，提高物理抓取成功率。

    相比原始 composite 的改进：
    1. geom size 0.004 → 0.007：碰撞体半径对齐 rmb 线缆
    2. friction "1.2 0.005 0.001" → "3 0.2 0.01"：对齐 rmb 的高摩擦
    3. density 1000 → 1200：增加质量，提高接触力

    几何对齐 flex：50 段、0.5m 总长、0.01m 段长
  -->

  <extension>
    <plugin plugin="mujoco.elasticity.cable"/>
  </extension>

  <default>
    <geom condim="4" friction="3 0.2 0.01" solref="0.01 0.5" solimp="0.9 0.95 0.001"/>
  </default>

  <worldbody>
    <body>
      <body name="object">
        <composite
          prefix="flexrefc_"
          type="cable"
          curve="s"
          count="50 1 1"
          size="0.5"
          offset="-0.25 0 0"
          initial="none"
        >
          <plugin plugin="mujoco.elasticity.cable">
            <config key="twist" value="1e3"/>
            <config key="bend" value="5e3"/>
            <config key="vmax" value="0"/>
          </plugin>
          <joint kind="main" damping="0.005" armature="0.0005"/>
          <geom
            type="capsule"
            size="0.007"
            group="0"
            rgba="0.8 0.2 0.2 1"
            density="1200"
          />
        </composite>
      </body>
      <site name="bottom_site" pos="0 0 -0.007" size="0.005" rgba="0 0 0 0"/>
      <site name="top_site" pos="0 0 0.007" size="0.005" rgba="0 0 0 0"/>
      <site name="horizontal_radius_site" pos="0.25 0 0" size="0.005" rgba="0 0 0 0"/>
    </body>
  </worldbody>

  <contact>
    <exclude body1="cable_B0" body2="cable_B1"/>
  </contact>
</mujoco>
