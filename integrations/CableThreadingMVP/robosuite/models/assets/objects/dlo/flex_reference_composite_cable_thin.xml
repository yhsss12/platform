<mujoco model="flex_reference_composite_cable_thin">
  <!--
    细径高段数 composite 线缆：通过减小半径和增加段数提高柔顺性。

    设计思路：
    - 半径 3mm（标准 4mm）：更细的碰撞体更容易穿过柱子间隙
    - 80 段（标准 50）：更细粒度的弯曲，更接近连续体行为
    - 保持 damping=0.02, armature=0.0005：composite_cable 成功的关键参数
    - 保持 bend=1.2e3, twist=3e2：与 flex 一致的弯曲刚度
    - condim=6, solref=0.006：匹配 flex 的接触参数
    - 段长 0.5/80 = 6.25mm，接近 flex 的 5mm 顶点间距
  -->

  <extension>
    <plugin plugin="mujoco.elasticity.cable"/>
  </extension>

  <default>
    <geom condim="6" friction="2.8 0.03 0.001" solref="0.006 1" solimp="0.96 0.992 0.0005" margin="0.001"/>
  </default>

  <worldbody>
    <body>
      <body name="object">
        <composite
          prefix="flexrefc_"
          type="cable"
          curve="s"
          count="80 1 1"
          size="0.5"
          offset="-0.25 0 0"
          initial="none"
        >
          <plugin plugin="mujoco.elasticity.cable">
            <config key="twist" value="3e2"/>
            <config key="bend" value="1.2e3"/>
            <config key="vmax" value="0"/>
          </plugin>
          <joint kind="main" damping="0.02" armature="0.0005"/>
          <geom
            type="capsule"
            size="0.003"
            group="0"
            rgba="0.2 0.6 0.9 1"
            density="1000"
          />
        </composite>
      </body>
      <site name="bottom_site" pos="0 0 -0.003" size="0.005" rgba="0 0 0 0"/>
      <site name="top_site" pos="0 0 0.003" size="0.005" rgba="0 0 0 0"/>
      <site name="horizontal_radius_site" pos="0.25 0 0" size="0.005" rgba="0 0 0 0"/>
    </body>
  </worldbody>
</mujoco>
