# =============================================================================
# EAI IDE 客户现场配置模板
# 用法：cp app.env.example .env && 按客户环境修改
# 说明：结构与项目根目录 .env + backend/.env.example 对齐；密码/IP 已脱敏
# 勿将填好真实密钥的 .env 提交 Git 或打入 Docker 镜像
# =============================================================================

# ---------- 对外地址（改为客户服务器 IP 或域名，须一致）----------
# 浏览器 / WebSocket / 前端打包（构建镜像时的 NEXT_PUBLIC_API_URL 应与此一致）
NEXT_PUBLIC_API_URL=http://CHANGE_ME_SERVER_IP:8000
# 采集端 Agent 回连、安装脚本等
PUBLIC_BASE_URL=http://CHANGE_ME_SERVER_IP:8000
# 可选：前端开发用（生产 Docker 一般用 3001）
# FRONTEND_ORIGIN=http://CHANGE_ME_SERVER_IP:3001

# ---------- 现场 compose 用 Redis 镜像（与 export 的 tar 一致）----------
REDIS_IMAGE=redis:7-alpine

# ---------- 以下变量仅在公司「docker compose build」时需要；现场 docker load 可整段删除 ----------
# POSTGRES_BASE_IMAGE=postgres:16
# MINIO_BASE_IMAGE=minio/minio:latest
# UBUNTU_BASE_IMAGE=ubuntu:22.04

# ---------- OpenAI 兼容网关（自动标注，可选）----------
OPENAI_BASE_URL=https://your-llm-gateway/v1
OPENAI_API_KEY=CHANGE_ME_LLM_API_KEY
OPENAI_MODEL=gemini-2.5-flash

# ---------- HDF5 / 数据路径 ----------
HDF5_DATA_DIR=/tmp/hdf5_data
# DATA_ASSETS_ROOT=
# DATA_PATH_ALLOWED_ROOTS=
# EAI_COLLECT_STORAGE_PARENT=

# ---------- PostgreSQL（与 docker-compose.postgres-minio.yml 内置库一致）----------
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=eai_ide
POSTGRES_PORT=5432
# host 网络：应用连本机 127.0.0.1（与 POSTGRES_PASSWORD 保持一致）
DATABASE_URL=postgresql+asyncpg://admin:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/eai_ide

# ---------- JWT / 会话（推荐 JWT_*；也兼容根目录旧名 SECRET_KEY / ALGORITHM / ACCESS_TOKEN_EXPIRE_MINUTES）----------
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# 兼容旧模板（无效，仅作提醒，请使用上一行 JWT_SECRET）：
# SECRET_KEY=
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------- MinIO（与内置 eai-minio 对齐；SDK 用 MINIO_ACCESS_KEY / MINIO_SECRET_KEY）----------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
# 服务端访问 MinIO（API 与 MinIO 同机 compose host 时用本机回环）
MINIO_ENDPOINT=127.0.0.1:9000
# 浏览器直传预签名 URL 使用的主机:端口（须与你在浏览器里能打开的地址一致，勿填 127.0.0.1）
MINIO_PUBLIC_ENDPOINT=CHANGE_ME_SERVER_IP:9000
MINIO_SECURE=false

# ---------- 队列（USE_QUEUE=true 推荐）----------
USE_QUEUE=true
AUTO_START_WORKERS=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ---------- Agent 隧道（可选）----------
# AGENT_TUNNEL_TOKEN=change-me

# ---------- 其他可选 ----------
EXPERIMENT_ENABLED=false
