# OpenAI 兼容网关配置（用于自动标注）
OPENAI_BASE_URL=https://kfc-api.sxxe.net
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gemini-3-pro-preview

# HDF5 数据目录
HDF5_DATA_DIR=/tmp/hdf5_data

# 数据库配置（仅 PostgreSQL，已从 SQLite 完全迁移）
# 请将 YOUR_PASSWORD 替换为实际密码
DATABASE_URL=postgresql+asyncpg://admin:YOUR_PASSWORD@172.18.0.93:5432/eai_ide
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 批量同步任务并发（POST /api/data-assets/sync/batch）
# SYNC_BATCH_MAX_CONCURRENT_GLOBAL=4
# SYNC_BATCH_MAX_CONCURRENT_PER_AGENT=1

# 后端对外可访问基址（供采集端 Agent 回连平台注册/心跳/隧道）
PUBLIC_BASE_URL=http://127.0.0.1:8000

# 实验子系统总开关（关闭后 /api/experiment 与实验埋点均静默）
EXPERIMENT_ENABLED=false

# Agent WebSocket 隧道 Token（开启后采集端必须携带 token 才能连隧道）
# AGENT_TUNNEL_TOKEN=change-me

# Agent 一键安装（linux.sh）生成 systemd + /opt/eai-agent/run-agent.sh
# 默认：venv + ROS；启用 Conda 时需同时配置 CONDA_SH 与 CONDA_ENV（与交互终端 conda→ROS→python 一致）
# AGENT_INSTALL_USE_CONDA=false
# AGENT_INSTALL_CONDA_SH=/home/ubuntu/miniconda3/etc/profile.d/conda.sh
# AGENT_INSTALL_CONDA_ENV=eai
# AGENT_INSTALL_ROS_SETUP=/opt/ros/humble/setup.bash
# AGENT_INSTALL_ROS_WS_SETUP=
# 默认 __SUDO_USER__：与执行 sudo 安装者同账户（推荐）。固定写 root 或某系统用户名可覆盖。
# AGENT_INSTALL_SERVICE_USER=__SUDO_USER__

# Agent 安装包签名校验（Ed25519 公钥列表，base64）
# AGENT_INSTALL_PUBKEYS_JSON=["<pubkey_b64>"]

# 统一任务队列（生产建议开启）
# USE_QUEUE=true
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# AUTO_START_WORKERS=true
# （后端启动时对四个队列分别 pgrep：缺哪个 worker 就只启哪个，避免个别进程退出后永远不补）
#
# 队列路由（可按环境调整）
# QUEUE_ANNOTATION=gpu_queue
# QUEUE_CONVERSION=cpu_queue
# QUEUE_COLLECT=collect_queue
# QUEUE_BATCH=io_queue
# QUEUE_EXPORT=io_queue
#
# 任务并发上限（worker 进程内闸门）
# TASK_CONCURRENCY_ANNOTATION=2
# TASK_CONCURRENCY_CONVERSION=3
# TASK_CONCURRENCY_COLLECT=2
# TASK_CONCURRENCY_BATCH=2
# TASK_CONCURRENCY_EXPORT=2
#
# 任务超时（秒）
# TASK_TIMEOUT_ANNOTATION_SECONDS=2400
# TASK_TIMEOUT_CONVERSION_SECONDS=3600
# TASK_TIMEOUT_COLLECT_SECONDS=1800
# TASK_TIMEOUT_BATCH_SECONDS=1800
# TASK_TIMEOUT_EXPORT_SECONDS=2400
#
# 队列背压（USE_QUEUE=true 时生效）：限制「Redis 排队 + worker 已开始执行」的总任务数，防止疯狂提交拖垮 CPU。
# 0 或未设置表示不限制。队列名需大写：cpu_queue → RQ_MAX_PENDING_CPU_QUEUE
# RQ_MAX_PENDING_CPU_QUEUE=24
# RQ_MAX_PENDING_IO_QUEUE=48
# RQ_MAX_PENDING_GPU_QUEUE=8
# RQ_MAX_PENDING_COLLECT_QUEUE=8

# 启动时清理磁盘缓存（后端 lifespan 执行一次；设为 false 可关闭）
# CLEAR_CACHE_ON_STARTUP=true
# CLEAR_CACHE_ON_STARTUP_SCOPE=all
#   all：data（.minio_view_cache + _minio_conversion_cache）+ project（与 POST /api/data-assets/cache/clear?scope=all 一致）
#   data / project：仅清一类

# 周期性缓存清理后台任务（CACHE_AUTO_CLEANUP_*，详见 cache_cleanup_service）
# CACHE_AUTO_CLEANUP_ENABLED=true
# CACHE_AUTO_CLEANUP_INTERVAL_MINUTES=1440
# CACHE_AUTO_CLEANUP_DATA_ENABLED=true
# CACHE_AUTO_CLEANUP_PROJECT_ENABLED=true

# 平台生成数据统一根目录（推荐置于代码仓库之外）。
# 未设置时保持旧布局：runtime_outputs/、runtime_assets/、logs/、backend/data/。
# 设置后，已迁移模块使用其下的 runs/、assets/、cache/、logs/、state/、tmp/。
# EAI_DATA_ROOT=/data/eai

# Isaac Lab 外部运行时（物块堆叠 Mimic 数据生成；需解压 IsaacLab 至 external/IsaacLab-main）
# ISAACLAB_ROOT=/path/to/third_party/IsaacLab
# ISAACLAB_RUNTIME_ENABLED=true
# ISAACLAB_OUTPUT_ROOT=runs/isaac_lab/jobs
# 留空时使用 $EAI_DATA_ROOT/runs/isaac_lab/seeds/stack_cube_seed.hdf5
# ISAACLAB_STACK_CUBE_DEFAULT_SEED=

# pi0 / openpi 训练 runner（Physical Intelligence openpi 项目，不内嵌源码）
# PI0_RUNNER_ENABLED=true
# OPENPI_ROOT=/path/to/openpi
# OPENPI_PYTHON=/path/to/openpi/.venv/bin/python
# 或使用 uv：OPENPI_PYTHON="uv run python"
# OPENPI_BASE_CONFIG=pi05_libero
# OPENPI_TRAIN_SCRIPT=/path/to/openpi/scripts/train.py
# PI0_TRAIN_MODE=openpi   # 默认；仅测试可设 shim（已废弃）

# L20 远程训练节点（SSH；密码/私钥勿提交仓库）
# TRAIN_NODE_L20_HOST=172.18.0.73
# TRAIN_NODE_L20_USER=zyf
# TRAIN_NODE_L20_PASSWORD=
# TRAIN_NODE_L20_SSH_KEY=/path/to/id_rsa
# TRAIN_NODE_L20_PORT=22
# TRAIN_NODE_L20_WORKDIR=/home/zyf/eai-idev2.1
# 远端数据根；留空时兼容旧的 <WORKDIR>/runtime_outputs 布局
# TRAIN_NODE_L20_DATA_ROOT=/data/eai
# TRAIN_NODE_L20_CONDA=/home/zyf/anaconda3/bin/conda
# TRAIN_NODE_L20_CONDA_ENV=cable-threading-mvp
# TRAIN_NODE_L20_PYTHON_BIN=/home/zyf/anaconda3/envs/cable-threading-mvp/bin/python

# 自动数据库备份（默认开启；每次写入 eai_ide_backup_YYYY-MM-DD.sql，按日独立文件不互相覆盖）
# DB_AUTO_BACKUP_ENABLED=true
# DB_AUTO_BACKUP_DAILY_HOUR=3
# DB_AUTO_BACKUP_DAILY_MINUTE=0
# DB_AUTO_BACKUP_OUTPUT_PATH=
#   留空 = 项目根目录（与 backend/ 同级）；或设为目录如 /var/backups/eai
#   若填旧的 xxx/eai_ide_backup.sql，则文件写入 xxx/eai_ide_backup_<日期>.sql
# DB_AUTO_BACKUP_RUN_ON_STARTUP=true
